<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/countriesFragment">

    <fragment
        android:id="@+id/countriesFragment"
        android:name="com.example.myapplication.ui.fragment.CountriesFragment"
        android:label="CountriesList"
        tools:layout="@layout/fragment_countries">

        <action
            android:id="@+id/action_countries_to_countryDetail"
            app:destination="@id/countryFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim"/>

    </fragment>


    <fragment
        android:id="@+id/countryFragment"
        android:name="com.example.myapplication.ui.fragment.CountryFragment"
        android:label="Country"
        tools:layout="@layout/fragment_country">

        <argument
            android:name="countryDetail"
            app:argType="com.example.core.model.countries.Country"
            app:nullable="true"
            android:defaultValue="@null" />

    </fragment>

    <!-- Settings Fragment -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.myapplication.ui.fragment.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings"/>

</navigation>